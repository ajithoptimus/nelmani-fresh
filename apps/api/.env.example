# Nelmani Fresh API — Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_NAME="Nelmani Fresh API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Neon PostgreSQL
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://neondb_owner:your_password@your-project.neon.tech/neondb?sslmode=require

# Connection Pooling
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=nelmani_products

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000/admin

# Email (optional — for order notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_EMAIL=orders@nelmani.fresh
EMAILS_FROM_NAME="Nelmani Fresh"

# WhatsApp Business (optional)
WHATSAPP_NUMBER=+91XXXXXXXXXX

# Shiprocket (Future Integration)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
